# ═══════════════════════════════════════════════════════════════
#  Awesome QR Code Docker — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#  Copy this file to .env and adjust to your needs.
#  All values shown are the defaults used when a variable is unset.
# ═══════════════════════════════════════════════════════════════

# ── Runtime ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── Public Domain / URLs ──────────────────────────────────────
#  The base URL where this application is publicly reachable.
#  Used for SEO canonical URLs, OpenGraph tags and short links.
PUBLIC_BASE_URL=http://localhost:3000

#  Optional dedicated (sub)domain for short links.
#  Falls back to PUBLIC_BASE_URL when empty.
#  Example: https://s.example.com
SHORT_LINK_DOMAIN=

# ── Feature Toggles ──────────────────────────────────────────
#  Master switch — enables tracked QR codes, short links & stats.
#  When false the app works without any database.
FEATURE_ANALYTICS=false

#  Expose a public API with Swagger / OpenAPI documentation.
FEATURE_SWAGGER=false

#  Resolve approximate country/region from IP (requires a
#  GeoIP database or Cloudflare/proxy headers).
FEATURE_GEOIP=false

# ── Database ──────────────────────────────────────────────────
#  Only required when FEATURE_ANALYTICS=true.
#  Dialect: postgres | mysql | sqlite
DATABASE_DIALECT=sqlite
DATABASE_URL=file:./data/awesome-qr.db

#  PostgreSQL example:
#  DATABASE_DIALECT=postgres
#  DATABASE_URL=postgresql://user:password@db:5432/awesome_qr

#  MariaDB / MySQL example:
#  DATABASE_DIALECT=mysql
#  DATABASE_URL=mysql://user:password@db:3306/awesome_qr

# ── Tracking / Scan Analytics ─────────────────────────────────
#  Default state of the "enable tracking" toggle in the UI.
TRACKING_DEFAULT_ENABLED=false

#  Which data points to collect per scan (individually toggleable).
TRACKING_CLICKS=true
TRACKING_TIMESTAMPS=true
TRACKING_BROWSER=true
TRACKING_OS=true
TRACKING_GEO=false
TRACKING_REFERRER=true
TRACKING_UNIQUE_VISITORS=false

#  Salt used for hashing IPs (unique-visitor counting).
#  CHANGE THIS to a long random string in production!
TRACKING_IP_SALT=change-me-to-a-random-string

#  Days to keep scan events before automatic cleanup. 0 = forever.
TRACKING_RETENTION_DAYS=90

# ── External Analytics Providers (website analytics) ──────────
#  Google Analytics measurement ID (e.g. G-XXXXXXXXXX).
GOOGLE_ANALYTICS_ID=

#  Cloudflare Web Analytics beacon token.
CLOUDFLARE_ANALYTICS_TOKEN=

# ── SEO ───────────────────────────────────────────────────────
SITE_NAME=Awesome QR Code
SITE_DESCRIPTION=Free, fast & customizable QR Code Generator
SITE_KEYWORDS=QR Code,Generator,Free,Analytics,Short Link
OG_IMAGE_URL=
TWITTER_HANDLE=
ROBOTS_POLICY=index,follow

# ── Branding ──────────────────────────────────────────────────
SITE_CLAIM=Generate beautiful QR codes in seconds
SITE_LOGO_URL=
FOOTER_TEXT=

# ── Internationalization ──────────────────────────────────────
DEFAULT_LOCALE=en
AVAILABLE_LOCALES=en,de

# ── Theme ─────────────────────────────────────────────────────
#  Default theme: light | dark | system
DEFAULT_THEME=system

#  Primary brand colour (hex). Used for accents and default QR fg.
PRIMARY_COLOR=#6366f1

# ── QR Code Defaults ─────────────────────────────────────────
QR_DEFAULT_SIZE=300
QR_DEFAULT_ERROR_CORRECTION=M
#  Maximum logo-to-QR area ratio (0.0–0.3). Larger = riskier.
QR_MAX_LOGO_RATIO=0.2

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Imprint (Impressum) ──────────────────────────────────────
IMPRINT_COMPANY=
IMPRINT_ADDRESS=
IMPRINT_EMAIL=
IMPRINT_PHONE=
IMPRINT_REGISTER=
IMPRINT_VAT_ID=
IMPRINT_RESPONSIBLE=
#  Raw HTML appended after the generated imprint block.
IMPRINT_CUSTOM_HTML=

# ── Privacy / Legal ──────────────────────────────────────────
PRIVACY_CONTACT_EMAIL=
PRIVACY_DPO_EMAIL=
#  Comma-separated list of extra section keys to append.
#  Sections are defined in messages/<locale>.json → privacy.sections.*
PRIVACY_CUSTOM_SECTIONS=
